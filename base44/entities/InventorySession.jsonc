{
  "name": "InventorySession",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "p\u00e5g\u00e5ende",
        "pausad",
        "avslutad"
      ],
      "default": "p\u00e5g\u00e5ende"
    },
    "mode": {
      "type": "string",
      "description": "location | open"
    },
    "location_id": {
      "type": "string",
      "nullable": true
    },
    "location_name": {
      "type": "string",
      "nullable": true
    },
    "tool_type": {
      "type": "string",
      "description": "Kommaseparerade typer, t.ex. 'tools,handtools'"
    },
    "checked_item_ids": {
      "type": "array",
      "description": "Lista med ID:n f\u00f6r kontrollerade artiklar",
      "items": {
        "type": "string"
      }
    },
    "manual_counts": {
      "type": "object",
      "description": "Manuellt inmatade antal per artikel-ID {id: antal}",
      "additionalProperties": true
    },
    "started_by_email": {
      "type": "string"
    },
    "started_by_name": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "paused_at": {
      "type": "string",
      "format": "date-time",
      "nullable": true
    }
  },
  "required": [
    "mode",
    "tool_type",
    "started_at"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "verktygsf\u00f6rvaltare"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}